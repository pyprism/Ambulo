# Environment configuration for Ambulo
# Auto-generated by Ansible — do not edit manually on the server

# Django Core Settings
secret_key='{{ django_secret_key }}'
debug={{ django_debug | lower }}
allowed_hosts={{ django_allowed_hosts | join(',') if django_allowed_hosts is iterable and django_allowed_hosts is not string else django_allowed_hosts }}
# Only used when debug=false: max-age for the Strict-Transport-Security header.
secure_hsts_seconds={{ secure_hsts_seconds | default(31536000) }}

# Database Configuration
db_name={{ db_name }}
db_user={{ db_user }}
db_password={{ db_password }}
db_host={{ db_host }}
db_port={{ db_port }}

# Docker Compose Settings
# Port on the host that maps to container port 8000
server_port={{ server_port }}

# Sentry (optional)
{% if sentry_dsn is defined and sentry_dsn %}
sentry_dsn={{ sentry_dsn }}
{% else %}
sentry_dsn=
{% endif %}
sentry_traces_sample_rate={{ sentry_traces_sample_rate | default(0.0) }}

# RabbitMQ (Celery broker)
rabbitmq_url={{ rabbitmq_url }}

# JWT token lifetimes
jwt_access_minutes={{ jwt_access_minutes | default(60) }}
jwt_refresh_days={{ jwt_refresh_days | default(30) }}

# Self-service registration (first registered user becomes staff/superuser)
registration_open={{ registration_open | lower }}
time_zone={{ time_zone }}
